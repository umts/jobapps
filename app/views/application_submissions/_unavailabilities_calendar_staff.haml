%table.calendar
  %thead
    %tr.hours-row
      %th.col-narrow
      - Unavailability::HOURS.each do |hour|
        %th.hours= hour
  %tbody
    - Date::DAYNAMES.each_with_index do |dow, i|
      %tr.dow-row
        %td.day.col-narrow= dow
        - Unavailability::HOURS.count.times do |j|
          - if unavailability.grid[i][j]
            %td.hours-checkbox.checked-off
          - else
            %td.hours-checkbox
